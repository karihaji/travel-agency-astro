---
const { plan } = Astro.props;
const { id, price } = plan;

// Safe formatting helper
const formatPrice = (p: any) => (typeof p === 'number' ? p.toLocaleString() : '0');

// Fallback to empty arrays if options are missing in microCMS
const transport_options = plan.transport_options || [];
const ac_options = plan.ac_options || [];
---

<div class="estimator-container">
  <h3>お見積もりシミュレーター</h3>
  
  <div class="input-group">
    <div class="field">
      <label for="departure-date">出発日</label>
      <input type="date" id="departure-date" />
    </div>
    <div class="field">
      <label for="arrival-date">到着日</label>
      <input type="date" id="arrival-date" />
    </div>
  </div>

  <div class="field">
    <label for="participants">参加人数</label>
    <input type="number" id="participants" value="1" min="1" />
  </div>

  <div class="field">
    <label for="transport">移動手段</label>
    <select id="transport">
      <option value="0">基本プラン (移動費なし)</option>
      {transport_options.map(opt => (
        <option value={opt?.price || 0}>{opt?.name || '不明なオプション'} (+{formatPrice(opt?.price)}円)</option>
      ))}
    </select>
  </div>

  <div class="field">
    <label for="accommodation">宿泊施設</label>
    <select id="accommodation">
      <option value="0">基本プラン (宿泊費なし)</option>
      {ac_options.map(opt => (
        <option value={opt?.price || 0}>{opt?.name || '不明なオプション'} (+{formatPrice(opt?.price)}円)</option>
      ))}
    </select>
  </div>

  <div class="result-box">
    <p class="total-label">概算合計金額:</p>
    <p class="total-amount"><span id="total-price">---</span>円</p>
    <p id="calc-warning" class="warning-text" style="display: none;">※ 人数、移動手段、宿泊施設をすべて正しく選択してください。</p>
  </div>

  <button id="reserve-btn" class="reserve-button" disabled>この条件で予約へ進む</button>
</div>

<script define:vars={{ basePrice: price, planId: id }}>
  const departureInput = document.getElementById('departure-date');
  const arrivalInput = document.getElementById('arrival-date');
  const participantsInput = document.getElementById('participants');
  const transportSelect = document.getElementById('transport');
  const acSelect = document.getElementById('accommodation');
  const totalPriceSpan = document.getElementById('total-price');
  const warningText = document.getElementById('calc-warning');
  const reserveButton = document.getElementById('reserve-btn');

  function updateEstimation() {
    const participants = parseInt(participantsInput.value) || 0;
    const transportVal = transportSelect.value;
    const acVal = acSelect.value;

    const transportPrice = parseInt(transportVal);
    const acPrice = parseInt(acVal);

    // バリデーション: 人数が1以上、かつ移動・宿泊が選択されていること
    const isSelectionValid = participants >= 1 && transportVal !== "" && acVal !== "";

    if (isSelectionValid) {
      const total = (basePrice + transportPrice + acPrice) * participants;
      totalPriceSpan.textContent = total.toLocaleString();
      warningText.style.display = 'none';
      reserveButton.disabled = false;
    } else {
      totalPriceSpan.textContent = '---';
      warningText.style.display = 'block';
      reserveButton.disabled = true;
    }
  }

  function goToReserve() {
    const params = new URLSearchParams({
      id: planId,
      participants: participantsInput.value,
      departure: departureInput.value,
      arrival: arrivalInput.value,
      total: totalPriceSpan.textContent.replace(/,/g, '')
    });
    window.location.href = `${import.meta.env.BASE_URL}reserve?${params.toString()}`;
  }

  // 各入力項目の変更を監視
  [participantsInput, transportSelect, acSelect].forEach(input => {
    input.addEventListener('change', updateEstimation);
    input.addEventListener('input', updateEstimation);
  });

  reserveButton.addEventListener('click', goToReserve);

  // 初回実行
  updateEstimation();
</script>

<style>
  .estimator-container {
    background-color: #f8f9fa;
    border: 2px solid #e9ecef;
    border-radius: 12px;
    padding: 1.5rem;
    max-width: 500px;
    margin: 2rem 0;
  .estimator-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field-group label {
    font-size: 0.9rem;
    font-weight: bold;
    color: #555;
  }

  .field-group input {
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 1rem;
    transition: border-color 0.2s;
  }

  .field-group input:focus {
    outline: none;
    border-color: #0d6efd;
    ring: 2px solid rgba(13, 110, 253, 0.1);
  }

  .result-box {
    padding: 1rem;
    margin-top: 1.5rem;
    text-align: center;
  }

  .total-label {
    margin: 0;
    font-size: 0.9rem;
    color: #6c757d;
  }

  .total-amount {
    margin: 0.5rem 0;
    font-size: 1.8rem;
    font-weight: bold;
    color: #0d6efd;
  }

  .warning-text {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: #dc3545;
  }

  .reserve-button {
    width: 100%;
    margin-top: 1rem;
    padding: 1rem;
    border: none;
    border-radius: 8px;
    background-color: #198754;
    color: white;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .reserve-button:hover:not(:disabled) {
    background-color: #146c43;
  }

  .reserve-button:disabled {
    background-color: #adb5bd;
    cursor: not-allowed;
  }
</style>
