---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTravelPlans } from '../../lib/microcms';

const { contents: plans } = await getTravelPlans();
const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base : base + '/';
---

<BaseLayout title="旅行企画一覧">
  <div class="container page-content">
    <h1 class="page-title">旅行企画一覧</h1>
    <p class="page-description">サンライズ旅行社がお届けする、現在募集中の旅行企画一覧です。お好みのプランをお選びください。</p>

    <div class="plan-list-grid">
      {plans.map((plan) => (
        <a href={`${normalizedBase}plans/${plan.id}`} class="plan-item-card">
          <div class="card-body">
            <h3>{plan.title}</h3>
            <p class="plan-price-large">基本料金: <span>{plan.price.toLocaleString()}円</span></p>
            <div class="card-footer">
              <span class="btn-text">詳細・シミュレーションへ &rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {plans.length === 0 && (
        <p class="no-data">現在、募集中の企画はございません。後ほど再度ご確認ください。</p>
    )}
  </div>

  <style>
    .page-content {
      padding: 4rem 1.5rem;
    }

    .page-title {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      text-align: center;
    }

    .page-description {
      text-align: center;
      color: #666;
      max-width: 600px;
      margin: 0 auto 4rem;
    }

    .plan-list-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
    }

    .plan-item-card {
      text-decoration: none;
      color: inherit;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
    }

    .plan-item-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 15px 30px rgba(0,0,0,0.1);
      border-color: var(--primary);
    }

    .card-body {
      padding: 2rem;
      flex-grow: 1;
    }

    .card-body h3 {
      margin: 0 0 1rem;
      font-size: 1.4rem;
      line-height: 1.4;
    }

    .plan-price-large {
      font-size: 1rem;
      color: #555;
    }

    .plan-price-large span {
      font-size: 1.5rem;
      font-weight: bold;
      color: var(--primary);
    }

    .card-footer {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }

    .btn-text {
      color: var(--primary);
      font-weight: bold;
      font-size: 0.9rem;
    }

    .no-data {
        text-align: center;
        padding: 4rem;
        color: #888;
    }

    @media (max-width: 768px) {
      .page-title {
        font-size: 2rem;
      }
    }
  </style>
</BaseLayout>
