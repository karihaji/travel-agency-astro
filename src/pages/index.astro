---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTravelPlans } from '../lib/microcms';

const { contents: allPlans } = await getTravelPlans();
const plans = allPlans.slice(0, 5);
const hasMore = allPlans.length > 5;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="ホーム">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1>特別な旅を、あなたに。</h1>
      <p>サンライズ旅行社が提案する、こころ動かす感動の旅路。</p>
      <a href={`${base}plans`} class="btn btn-primary">プラン一覧を見る</a>
    </div>
  </section>

  <!-- Company Summary -->
  <section class="company-intro">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-text">
          <h2 class="section-title">私たちについて</h2>
          <p>サンライズ旅行社は、創業以来「一生の思い出に残る旅」を提供し続けています。厳選された宿泊施設と、お客様一人ひとりに合わせた最適なプランニングで、高品質な旅の体験をお約束します。</p>
          <a href={`${base}company`} class="text-link">会社案内はこちら &rarr;</a>
        </div>
        <div class="intro-visual">
          <div class="visual-box">
             <img src={`${base}hero.png`} alt="Travel Visual" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Plans -->
  <section class="featured-plans">
    <div class="container">
      <h2 class="section-title">おすすめの旅行企画</h2>
      <div class="plan-grid">
        {plans.map((plan) => (
          <a href={`${base}plans/${plan.id}`} class="plan-card">
            <div class="plan-info">
              <h3>{plan.title}</h3>
              <p class="plan-price">基本料金: <span>{plan.price.toLocaleString()}円</span></p>
              <span class="view-detail">詳細を見る</span>
            </div>
          </a>
        ))}
      </div>

      {hasMore && (
        <div class="view-all">
          <a href={`${base}plans`} class="btn btn-outline">すべてのプランを見る ({allPlans.length}件)</a>
        </div>
      )}
    </div>
  </section>

  <style>
    /* Hero */
    .hero {
      position: relative;
      height: 60vh;
      min-height: 400px;
      background-image: url('/travel-agency-astro/hero.png');
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: center;
      color: #fff;
      margin-bottom: 4rem;
    }

    .hero-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.4);
    }

    .hero-content {
      position: relative;
      z-index: 1;
      text-align: center;
    }

    .hero h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    .hero p {
      font-size: 1.25rem;
      margin-bottom: 2rem;
    }

    /* Intro */
    .intro-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      margin-bottom: 4rem;
    }

    .visual-box img {
      width: 100%;
      border-radius: 12px;
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    /* Section Title */
    .section-title {
      font-size: 1.75rem;
      margin-bottom: 2rem;
      position: relative;
      display: inline-block;
    }

    .section-title::after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 0;
      width: 50px;
      height: 3px;
      background: var(--primary);
    }

    /* Plan Grid */
    .plan-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .plan-card {
      text-decoration: none;
      color: inherit;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .plan-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    .plan-info {
      padding: 1.5rem;
    }

    .plan-info h3 {
      margin: 0 0 0.5rem;
      font-size: 1.2rem;
      color: var(--dark);
    }

    .plan-price {
      color: #666;
      font-size: 0.9rem;
    }

    .plan-price span {
      font-weight: bold;
      color: var(--primary);
      font-size: 1.1rem;
    }

    .view-detail {
      display: block;
      margin-top: 1rem;
      font-weight: bold;
      color: var(--primary);
      font-size: 0.9rem;
    }

    /* Common Components */
    .btn {
      display: inline-block;
      padding: 0.75rem 2rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: bold;
      transition: background 0.2s;
    }

    .btn-primary {
      background: var(--primary);
      color: #fff;
    }

    .btn-primary:hover {
      background: var(--primary-hover);
    }

    .btn-outline {
      border: 2px solid var(--primary);
      color: var(--primary);
    }

    .btn-outline:hover {
      background: var(--primary);
      color: #fff;
    }

    .view-all {
        text-align: center;
    }

    .text-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: bold;
    }

    @media (max-width: 768px) {
      .intro-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      .hero h1 {
        font-size: 2rem;
      }
    }
  </style>
</BaseLayout>
