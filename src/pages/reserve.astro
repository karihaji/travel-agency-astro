---
import BaseLayout from '../layouts/BaseLayout.astro';

const RECAPTCHA_SITE_KEY = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base : base + '/';
---

<BaseLayout title="ご予約画面">
  <section class="bg-ocean-800 py-12 text-white">
    <div class="container text-center">
      <h1 class="text-3xl md:text-4xl font-bold">お申し込みフォーム</h1>
    </div>
  </section>

  <div class="container py-12">
    <div id="no-plan-error" class="max-w-2xl mx-auto p-12 bg-white rounded-3xl border border-slate-200 text-center shadow-xl hidden">
      <div class="text-5xl mb-6">⚠️</div>
      <h2 class="text-xl font-bold text-slate-800 mb-4">プラン情報が見つかりません</h2>
      <p class="text-slate-500 mb-8 text-sm leading-relaxed">セッションがタイムアウトしたか、不正なアクセスです。<br/>お手数ですが一覧から再度プランを選択してください。</p>
      <a href={`${normalizedBase}plans/`} class="btn btn-primary inline-flex items-center gap-2">
         <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
           <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
         </svg>
         企画一覧に戻る
      </a>
    </div>

    <div id="reservation-container" class="max-w-4xl mx-auto opacity-0 transition-opacity duration-500">
      <!-- Plan Summary Header -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6 md:p-8 shadow-sm flex flex-col md:flex-row justify-between items-center gap-6 mb-12 border-l-8 border-l-ocean-600">
         <div>
            <span class="text-xs font-bold text-ocean-600 uppercase tracking-widest block mb-1">お申し込み内容</span>
            <h2 id="plan-title-display" class="text-xl md:text-2xl font-black text-slate-900 leading-tight">--</h2>
            <div class="mt-3 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-500 font-medium">
               <span class="flex items-center gap-2 italic">📅 出発予定日: <strong id="departure-display" class="text-slate-800 not-italic">--</strong></span>
               <span class="flex items-center gap-2 italic">👥 参加人数: <strong id="participants-display" class="text-slate-800 not-italic">大人 --名 / 小人 --名</strong></span>
            </div>
         </div>
         <div class="text-center md:text-right bg-ocean-50 px-6 py-4 rounded-xl border border-ocean-100">
            <span class="text-xs text-ocean-600 block mb-1 font-bold">概算合計金額</span>
            <div class="flex items-baseline justify-center md:justify-end gap-1">
               <span id="total-display" class="text-3xl font-black text-ocean-800 tracking-tight">--</span>
               <span class="text-sm font-bold text-ocean-800">円</span>
            </div>
         </div>
      </div>

      <div class="relative bg-white rounded-3xl border border-slate-200 shadow-2xl overflow-hidden min-h-[600px]">
        <!-- Step Indicator -->
        <div class="flex items-center justify-between px-8 md:px-20 py-10 bg-slate-50 border-b border-slate-100">
           {[1, 2, 3, 4].map((s) => (
              <div class="flex flex-col items-center gap-2 relative z-10 flex-1 last:flex-none">
                <div 
                  id={`step-dot-${s}`} 
                  class={`step-dot w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm transition-all duration-300 ${s === 1 ? 'bg-ocean-600 text-white shadow-lg shadow-ocean-200' : 'bg-white border-2 border-slate-200 text-slate-300'}`}
                >
                  {s}
                </div>
                {s < 4 && <div id={`divider-${s}`} class="step-divider absolute left-[calc(50%+20px)] right-[-50%] top-5 h-0.5 bg-slate-200 -z-10"></div>}
              </div>
           ))}
        </div>

        <form id="reservation-form" class="p-8 md:p-12">
          <!-- STEP 1: 代表者情報 -->
          <div class="form-step space-y-8" id="step-1">
            <div class="relative">
              <h3 class="text-2xl font-bold text-slate-800 mb-2">代表者情報</h3>
              <p class="text-slate-400 text-sm">ご連絡を差し上げる代表者様の情報を入力してください</p>
              <div class="absolute -left-12 top-2 h-8 w-1 bg-ocean-500 rounded-full hidden md:block"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-700">お名前 <span class="text-red-500">*</span></label>
                <input type="text" name="representativeName" required placeholder="例：山田 太郎" class="form-input" />
              </div>
              <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-700">ふりがな <span class="text-red-500">*</span></label>
                <input type="text" name="representativeKana" required placeholder="例：やまだ たろう" class="form-input" />
              </div>
              <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-700">メールアドレス <span class="text-red-500">*</span></label>
                <input type="email" name="email" required placeholder="info@ichimaru-grp.jp" class="form-input" />
              </div>
              <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-700">電話番号 <span class="text-red-500">*</span></label>
                <input type="tel" name="phone" required placeholder="090-0000-0000" class="form-input" />
              </div>
            </div>

            <div class="flex justify-end pt-8">
              <button type="button" class="btn btn-primary next-btn px-12" data-next="2">同行者情報の入力へ &rarr;</button>
            </div>
          </div>

          <!-- STEP 2: 同行者情報 -->
          <div class="form-step hidden space-y-8" id="step-2">
            <div class="relative">
              <h3 class="text-2xl font-bold text-slate-800 mb-2">同行者情報</h3>
              <p class="text-slate-400 text-sm">代表者様以外の参加者名をご記入ください（任意）</p>
              <div class="absolute -left-12 top-2 h-8 w-1 bg-ocean-500 rounded-full hidden md:block"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-700">同行者 1</label>
                <input type="text" name="companion1" placeholder="お名前をご記入ください" class="form-input" />
              </div>
              <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-700">同行者 2</label>
                <input type="text" name="companion2" placeholder="お名前をご記入ください" class="form-input" />
              </div>
            </div>

            <div class="flex justify-between pt-8">
              <button type="button" class="btn bg-slate-100 text-slate-600 hover:bg-slate-200 prev-btn px-8" data-prev="1">戻る</button>
              <button type="button" class="btn btn-primary next-btn px-12" data-next="3">次へ進む &rarr;</button>
            </div>
          </div>

          <!-- STEP 3: その他ご要望 -->
          <div class="form-step hidden space-y-8" id="step-3">
            <div class="relative">
              <h3 class="text-2xl font-bold text-slate-800 mb-2">その他ご要望</h3>
              <p class="text-slate-400 text-sm">アレルギーや持病、配慮が必要な事項などございましたらご記入ください</p>
              <div class="absolute -left-12 top-2 h-8 w-1 bg-ocean-500 rounded-full hidden md:block"></div>
            </div>

            <div class="space-y-2">
              <textarea name="requests" rows="6" placeholder="何かございましたらお気軽にご記入ください。" class="form-input resize-none p-5"></textarea>
            </div>

            <div class="flex justify-between pt-8">
              <button type="button" class="btn bg-slate-100 text-slate-600 hover:bg-slate-200 prev-btn px-8" data-prev="2">戻る</button>
              <button type="button" class="btn btn-primary next-btn px-12" data-next="4">入力内容を確認する &rarr;</button>
            </div>
          </div>

          <!-- STEP 4: 確認画面 -->
          <div class="form-step hidden space-y-8" id="step-4">
            <div class="relative">
              <h3 class="text-2xl font-bold text-slate-800 mb-2">最終確認</h3>
              <p class="text-slate-400 text-sm">入力内容に間違いがないかご確認ください</p>
              <div class="absolute -left-12 top-2 h-8 w-1 bg-ocean-500 rounded-full hidden md:block"></div>
            </div>

            <div class="bg-ocean-50 rounded-2xl p-8 border border-ocean-100 space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-12">
                 <div class="pb-4 border-b border-ocean-100">
                    <span class="text-xs font-bold text-ocean-400 uppercase tracking-widest block mb-1">お名前</span>
                    <p class="font-bold text-slate-800 text-lg" id="confirm-name">--</p>
                 </div>
                 <div class="pb-4 border-b border-ocean-100">
                    <span class="text-xs font-bold text-ocean-400 uppercase tracking-widest block mb-1">連絡先電話番号</span>
                    <p class="font-bold text-slate-800 text-lg" id="confirm-phone">--</p>
                 </div>
                 <div class="pb-4 border-b border-ocean-100 lg:col-span-2">
                    <span class="text-xs font-bold text-ocean-400 uppercase tracking-widest block mb-1">メールアドレス</span>
                    <p class="font-bold text-slate-800" id="confirm-email">--</p>
                 </div>
              </div>
              
              <div class="pt-2 text-sm text-slate-500 italic">
                 ※このボタンを押すと、予約申し込みが送信されます。担当者からの連絡をもって予約成立となります。
              </div>
            </div>

            <div class="flex flex-col md:flex-row items-center justify-center gap-4 pt-8">
              <button type="button" class="btn bg-white border border-slate-200 text-slate-500 hover:bg-slate-50 prev-btn px-8 w-full md:w-auto" data-prev="3">内容を修正する</button>
              <button type="submit" class="btn btn-primary w-full md:min-w-[300px] text-lg py-4 shadow-xl shadow-ocean-200" id="submit-btn">予約を確定する</button>
            </div>
          </div>
          
          <!-- Hidden context data from URL -->
          <input type="hidden" name="planId" id="hidden-plan-id" />
          <input type="hidden" name="planTitle" id="hidden-plan-title" />
          <input type="hidden" name="adultCount" id="hidden-adult-count" />
          <input type="hidden" name="childCount" id="hidden-child-count" />
          <input type="hidden" name="departureDate" id="hidden-departure-date" />
          <input type="hidden" name="totalAmount" id="hidden-total-amount" />
        </form>
        
        <div class="p-8 text-center bg-slate-50 border-t border-slate-100">
           <p class="text-[10px] text-slate-400">
              This site is protected by reCAPTCHA and the Google <a href="#" class="underline">Privacy Policy</a> and <a href="#" class="underline">Terms of Service</a> apply.
           </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script src={`https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`}></script>
<script define:vars={{ RECAPTCHA_SITE_KEY }}>
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const planId = params.get('id');
    const planTitle = params.get('title');
    const adult = params.get('adult');
    const child = params.get('child');
    const departure = params.get('departure');
    const total = params.get('total');

    if (!planId) {
      document.getElementById('no-plan-error').classList.remove('hidden');
      return;
    }

    // Populate UI
    document.getElementById('plan-title-display').textContent = planTitle || '旅行プラン';
    document.getElementById('departure-display').textContent = departure || '--';
    document.getElementById('participants-display').textContent = `大人 ${adult || 1}名 / 小人 ${child || 0}名`;
    document.getElementById('total-display').textContent = Number(total || 0).toLocaleString();

    // Populate hidden inputs
    document.getElementById('hidden-plan-id').value = planId;
    document.getElementById('hidden-plan-title').value = planTitle;
    document.getElementById('hidden-adult-count').value = adult;
    document.getElementById('hidden-child-count').value = child;
    document.getElementById('hidden-departure-date').value = departure;
    document.getElementById('hidden-total-amount').value = total;

    document.getElementById('reservation-container').classList.remove('opacity-0');

    // Multi-step logic
    const steps = document.querySelectorAll('.form-step');
    const form = document.getElementById('reservation-form');
    const confirmName = document.getElementById('confirm-name');
    const confirmEmail = document.getElementById('confirm-email');
    const confirmPhone = document.getElementById('confirm-phone');

    document.querySelectorAll('.next-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-next');
        const currentStep = btn.closest('.form-step');
        
        if (id === '2') {
           const requireds = currentStep.querySelectorAll('input[required]');
           let isValid = true;
           requireds.forEach(i => {
             if(!i.value) { i.classList.add('border-red-400'); isValid = false; }
             else { i.classList.remove('border-red-400'); }
           });
           if (!isValid) return;
        }

        showStep(id);
        if (id === '4') {
          const fd = new FormData(form);
          confirmName.textContent = fd.get('representativeName');
          confirmEmail.textContent = fd.get('email');
          confirmPhone.textContent = fd.get('phone');
        }
      });
    });

    document.querySelectorAll('.prev-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        showStep(btn.getAttribute('data-prev'));
      });
    });

    function showStep(id) {
      steps.forEach(s => s.classList.add('hidden'));
      document.getElementById(`step-${id}`).classList.remove('hidden');
      
      for (let i = 1; i <= 4; i++) {
        const dot = document.getElementById(`step-dot-${i}`);
        const div = document.getElementById(`divider-${i}`);
        if(i == id) {
          dot.className = 'step-dot w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm bg-ocean-600 text-white shadow-lg shadow-ocean-200';
        } else if (i < id) {
          dot.className = 'step-dot w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm bg-ocean-100 text-ocean-700 border-ocean-300';
          if(div) div.classList.add('bg-ocean-400');
        } else {
          dot.className = 'step-dot w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm bg-white border-2 border-slate-200 text-slate-300';
          if(div) div.classList.remove('bg-ocean-400');
        }
      }
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      btn.disabled = true;
      btn.textContent = '送信中...';
      try {
        await grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'reserve' });
        alert('予約申し込みを送信しました。担当者より折り返しご連絡いたします。');
        window.location.href = normalizedBase;
      } catch (err) {
        alert('エラーが発生しました。お手数ですがお電話にてお問い合わせください。');
        btn.disabled = false;
        btn.textContent = '予約を確定する';
      }
    });
  });
</script>
