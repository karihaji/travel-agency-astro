---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTravelPlan } from '../lib/microcms';

const { searchParams } = Astro.url;
const planId = searchParams.get('id');
const adultCount = searchParams.get('adult');
const childCount = searchParams.get('child');
const departureDate = searchParams.get('departure');
const totalAmount = searchParams.get('total');

const plan = planId ? await getTravelPlan(planId) : null;
const RECAPTCHA_SITE_KEY = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
const GAS_URL = import.meta.env.PUBLIC_GAS_URL;
---

<BaseLayout title="ご予約画面">
  <div class="container page-content">
    <div class="reservation-container">
      <h1 class="page-title">ご予約フォーム</h1>

      {!plan ? (
        <div class="error-msg">
          <p>プラン情報が見つかりません。一覧から再度プランを選択してください。</p>
          <a href={`${import.meta.env.BASE_URL}plans`} class="btn btn-outline">一覧に戻る</a>
        </div>
      ) : (
        <div class="reservation-wrapper">
          <div class="plan-summary-bar">
             <h2>{plan.title}</h2>
             <div class="summary-details">
                <span>出発日: {departureDate}</span>
                <span>人数: 大人{adultCount}名 / 小人{childCount}名</span>
                <span class="total-price">合計金額: {Number(totalAmount).toLocaleString()}円</span>
             </div>
          </div>

          <div class="form-stepper">
            <div class="step active" id="step-dot-1">1</div>
            <div class="step-divider"></div>
            <div class="step" id="step-dot-2">2</div>
            <div class="step-divider"></div>
            <div class="step" id="step-dot-3">3</div>
            <div class="step-divider"></div>
            <div class="step" id="step-dot-4">4</div>
          </div>

          <form id="reservation-form">
            <!-- STEP 1: 代表者情報 -->
            <div class="form-step" id="step-1">
              <h3>STEP 1: 代表者情報を入力してください</h3>
              <div class="form-group">
                <label>お名前 (フルネーム/漢字)</label>
                <input type="text" name="representativeName" required placeholder="例：山田 太郎" />
              </div>
              <div class="form-group">
                <label>ふりがな</label>
                <input type="text" name="representativeKana" required placeholder="例：やまだ たろう" />
              </div>
              <div class="form-group">
                <label>メールアドレス</label>
                <input type="email" name="email" required placeholder="example@sunrise-travel.jp" />
              </div>
              <div class="form-group">
                <label>電話番号</label>
                <input type="tel" name="phone" required placeholder="090-0000-0000" />
              </div>
              <div class="form-actions">
                <button type="button" class="btn btn-primary next-btn" data-next="2">次へ進む</button>
              </div>
            </div>

            <!-- STEP 2: 同行者情報 -->
            <div class="form-step hidden" id="step-2">
              <h3>STEP 2: 同行者情報を入力してください</h3>
              <p class="step-info">代表者様以外の参加者名をご記入ください（任意）。</p>
              <div class="form-group">
                <label>同行者1</label>
                <input type="text" name="companion1" placeholder="同行者のお名前" />
              </div>
              <div class="form-group">
                <label>同行者2</label>
                <input type="text" name="companion2" placeholder="同行者のお名前" />
              </div>
              <div class="form-actions">
                <button type="button" class="btn btn-light prev-btn" data-prev="1">戻る</button>
                <button type="button" class="btn btn-primary next-btn" data-next="3">次へ進む</button>
              </div>
            </div>

            <!-- STEP 3: その他ご要望 -->
            <div class="form-step hidden" id="step-3">
              <h3>STEP 3: その他ご要望</h3>
              <div class="form-group">
                <label>アレルギーや特記事項など</label>
                <textarea name="requests" rows="5" placeholder="何かございましたらご記入ください。"></textarea>
              </div>
              <div class="form-actions">
                <button type="button" class="btn btn-light prev-btn" data-prev="2">戻る</button>
                <button type="button" class="btn btn-primary next-btn" data-next="4">入力内容を確認する</button>
              </div>
            </div>

            <!-- STEP 4: 確認画面 -->
            <div class="form-step hidden" id="step-4">
              <h3>STEP 4: 入力内容の最終確認</h3>
              <div class="confirmation-box">
                <p><strong>プラン:</strong> {plan.title}</p>
                <p><strong>日程:</strong> {departureDate}</p>
                <p><strong>合計:</strong> {Number(totalAmount).toLocaleString()}円</p>
                <div id="summary-data"></div>
              </div>
              <div class="form-actions">
                <button type="button" class="btn btn-light prev-btn" data-prev="3">戻る</button>
                <button type="submit" class="btn btn-success" id="submit-btn">予約を確定する</button>
              </div>
            </div>
            
            <!-- Hidden context data -->
            <input type="hidden" name="planId" value={planId} />
            <input type="hidden" name="planTitle" value={plan?.title} />
            <input type="hidden" name="adultCount" value={adultCount} />
            <input type="hidden" name="childCount" value={childCount} />
            <input type="hidden" name="departureDate" value={departureDate} />
            <input type="hidden" name="totalAmount" value={totalAmount} />
          </form>
          <p class="recaptcha-notice">This site is protected by reCAPTCHA and the Google Privacy Policy and Terms of Service apply.</p>
        </div>
      )}
    </div>
  </div>

  <script src={`https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`}></script>
  <script define:vars={{ RECAPTCHA_SITE_KEY, GAS_URL }}>
    const steps = document.querySelectorAll('.form-step');
    const dots = document.querySelectorAll('.step');
    const form = document.getElementById('reservation-form');
    const summaryDisplay = document.getElementById('summary-data');

    // Navigation Logic
    document.querySelectorAll('.next-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const nextStepId = btn.getAttribute('data-next');
        showStep(nextStepId);
        if(nextStepId === '4') updateSummary();
      });
    });

    document.querySelectorAll('.prev-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        showStep(btn.getAttribute('data-prev'));
      });
    });

    function showStep(id) {
      steps.forEach(s => s.classList.add('hidden'));
      document.getElementById(`step-${id}`).classList.remove('hidden');
      
      dots.forEach((d, idx) => {
        if(idx + 1 <= id) d.classList.add('active');
        else d.classList.remove('active');
      });
      window.scrollTo(0, 0);
    }

    function updateSummary() {
      const fd = new FormData(form);
      summaryDisplay.innerHTML = `
        <p><strong>お名前:</strong> ${fd.get('representativeName')}</p>
        <p><strong>メール:</strong> ${fd.get('email')}</p>
        <p><strong>電話:</strong> ${fd.get('phone')}</p>
      `;
    }

    // Submission Logic
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submit-btn');
      submitBtn.disabled = true;
      submitBtn.textContent = '送信中...';

      try {
        const token = await grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'reserve' });
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        data['g-recaptcha-response'] = token;

        const response = await fetch(GAS_URL, {
          method: 'POST',
          mode: 'no-cors',
          body: new URLSearchParams(data)
        });

        alert('予約の送信が完了しました。確認メールが届くのを待ちください。');
        window.location.href = import.meta.env.BASE_URL;
      } catch (err) {
        alert('エラーが発生しました。時間を置いて再度お試しください。');
        submitBtn.disabled = false;
        submitBtn.textContent = '予約を確定する';
      }
    });
  </script>

  <style>
    .page-content { padding: 4rem 1.5rem; }
    .reservation-container { max-width: 800px; margin: 0 auto; }
    .page-title { text-align: center; margin-bottom: 3rem; font-size: 2rem; }

    .plan-summary-bar { background: var(--dark); color: #fff; padding: 1.5rem 2rem; border-radius: 8px; margin-bottom: 2rem; }
    .plan-summary-bar h2 { margin: 0 0 0.5rem; font-size: 1.25rem; }
    .summary-details { display: flex; gap: 1.5rem; font-size: 0.9rem; color: #ccc; }
    .total-price { color: #fff; font-weight: bold; }

    /* Stepper */
    .form-stepper { display: flex; align-items: center; justify-content: center; margin-bottom: 3rem; }
    .step { width: 40px; height: 40px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-weight: bold; color: var(--border); background: #fff; }
    .step.active { border-color: var(--primary); color: var(--primary); box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1); }
    .step-divider { width: 50px; height: 2px; background: var(--border); margin: 0 10px; }

    /* Form Styles */
    .reservation-wrapper { background: #fff; border: 1px solid var(--border); padding: 3rem; border-radius: 12px; }
    .form-step h3 { margin-top: 0; margin-bottom: 2rem; font-size: 1.3rem; color: var(--primary); }
    .hidden { display: none; }

    .form-group { margin-bottom: 1.5rem; }
    .form-group label { display: block; font-weight: bold; margin-bottom: 0.5rem; color: #444; }
    .form-group input, .form-group textarea { width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 6px; font-size: 1rem; }
    
    .form-actions { display: flex; gap: 1rem; margin-top: 2rem; }
    .btn { padding: 0.8rem 2rem; border-radius: 6px; font-weight: bold; cursor: pointer; border: none; font-size: 1rem; }
    .btn-light { background: var(--light); color: var(--dark); border: 1px solid var(--border); }
    .btn-success { background: var(--secondary); color: #fff; }
    .confirmation-box { background: var(--light); padding: 2rem; border-radius: 8px; margin-bottom: 2rem; }

    .recaptcha-notice { font-size: 0.7rem; color: #999; margin-top: 2rem; text-align: center; }
  </style>
</BaseLayout>
