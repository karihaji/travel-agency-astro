---
const { title } = Astro.props;
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base : base + '/';

const navItems = [
  { label: 'ホーム', href: normalizedBase },
  { label: '旅行企画', href: `${normalizedBase}plans/` },
  { label: '会社案内', href: `${normalizedBase}company/` },
  { label: 'FAQ/お問い合わせ', href: `${normalizedBase}faq-contact/` },
];
---

<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | わかさ旅行センター</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50">
    <header class="sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md shadow-sm border-b border-slate-100">
      <div class="container py-4 flex justify-between items-center">
        <a href={normalizedBase} class="text-2xl font-black tracking-tight text-ocean-900 flex items-center gap-2 group">
          <span class="w-10 h-10 bg-ocean-600 rounded-xl flex items-center justify-center text-white text-xl shadow-lg group-hover:bg-ocean-700 transition-colors">W</span>
          <span class="hidden sm:inline">わかさ旅行センター</span>
        </a>
        
        <nav class="hidden md:block">
          <ul class="flex gap-8">
            {navItems.map(item => (
              <li>
                <a 
                  href={item.href} 
                  class="text-slate-600 hover:text-ocean-600 font-medium transition-colors py-2 border-b-2 border-transparent hover:border-ocean-600"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Mobile Menu Button (visible on md and below if we wanted, but keeping it simple for now) -->
        <button class="md:hidden p-2 text-slate-600">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-ocean-900 text-white mt-20 pt-16 pb-8">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 border-b border-ocean-800 pb-12">
          <div>
            <h3 class="text-xl font-bold mb-6">わかさ旅行センター</h3>
            <div class="space-y-3 text-ocean-200">
              <p>〒891-3111 鹿児島県西之表市栄町1番地</p>
              <p>TEL: 0997-22-2333</p>
              <p class="text-sm">営業時間: 08:00〜17:00（日・祝定休）</p>
            </div>
          </div>
          
          <div>
            <h4 class="font-bold mb-6 text-ocean-100">メニュー</h4>
            <ul class="grid grid-cols-2 gap-4">
              {navItems.map(item => (
                <li>
                  <a href={item.href} class="text-ocean-200 hover:text-white transition-colors">
                    {item.label}
                  </a>
                </li>
              ))}
              <li><a href={`${normalizedBase}company#legal`} class="text-ocean-200 hover:text-white transition-colors">旅行業の法定標識</a></li>
              <li><a href={`${normalizedBase}company#policy`} class="text-ocean-200 hover:text-white transition-colors">個人情報保護方針</a></li>
            </ul>
          </div>

          <div>
            <h4 class="font-bold mb-6 text-ocean-100">運営</h4>
            <div class="text-ocean-200 text-sm space-y-2">
              <p>熊毛海陸運送株式会社 わかさ旅行センター</p>
              <p>フェリープリンセスわかさ・フェリー屋久島2 関連会社</p>
            </div>
          </div>
        </div>
        
        <div class="mt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-ocean-400">
          <p>&copy; {new Date().getFullYear()} 熊毛海陸運送株式会社 わかさ旅行センター. All rights reserved.</p>
          <div class="flex gap-6">
             <a href="#" class="hover:text-white transition-colors">旅行条件書</a>
             <a href="#" class="hover:text-white transition-colors">個人情報保護方針</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
