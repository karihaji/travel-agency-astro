---
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base : base + '/';
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | サンライズ旅行社</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="main-header">
      <div class="container header-content">
        <a href={normalizedBase} class="logo">
          <span class="logo-icon">☀️</span>
          <span class="logo-text">サンライズ旅行社</span>
        </a>
        <nav class="nav-menu">
          <ul>
            <li><a href={normalizedBase}>トップ</a></li>
            <li><a href={`${normalizedBase}plans`}>旅行企画一覧</a></li>
            <li><a href={`${normalizedBase}faq-contact`}>よくある質問・問合せ</a></li>
            <li><a href={`${normalizedBase}company`}>会社概要</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="main-footer">
      <div class="container footer-content">
        <div class="footer-info">
          <h3>サンライズ旅行社</h3>
          <p>〒100-0001 東京都千代田区千代田1-1</p>
          <p>TEL: 03-1234-5678</p>
        </div>
        <div class="footer-links">
          <ul>
            <li><a href={`${normalizedBase}company`}>旅行条件書</a></li>
            <li><a href={`${normalizedBase}company`}>個人情報保護方針</a></li>
          </ul>
        </div>
      </div>
      <div class="copyright">
        <p>&copy; 2026 Sunrise Travel Agency. All Rights Reserved.</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --primary: #0d6efd;
        --primary-hover: #0b5ed7;
        --secondary: #198754;
        --dark: #212529;
        --light: #f8f9fa;
        --border: #dee2e6;
        --text: #333;
        --container-width: 1000px;
        --font-main: 'Inter', 'Noto Sans JP', sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        font-family: var(--font-main);
        color: var(--text);
        background-color: #fff;
        line-height: 1.6;
      }

      .container {
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* Header */
      .main-header {
        background: #fff;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 1000;
        padding: 1rem 0;
      }

      .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .logo-icon {
        font-size: 1.5rem;
      }

      .logo-text {
        font-size: 1.25rem;
        font-weight: bold;
        color: var(--dark);
      }

      .nav-menu ul {
        list-style: none;
        display: flex;
        gap: 1.5rem;
        margin: 0;
        padding: 0;
      }

      .nav-menu a {
        text-decoration: none;
        color: var(--text);
        font-weight: 500;
        transition: color 0.2s;
      }

      .nav-menu a:hover {
        color: var(--primary);
      }

      /* Footer */
      .main-footer {
        background: var(--dark);
        color: #fff;
        padding: 4rem 0 2rem;
        margin-top: 4rem;
      }

      .footer-content {
        display: flex;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
      }

      .footer-info h3 {
        margin-top: 0;
      }

      .footer-links ul {
        list-style: none;
        padding: 0;
      }

      .footer-links a {
        color: #bbb;
        text-decoration: none;
      }

      .footer-links a:hover {
        color: #fff;
      }

      .copyright {
        text-align: center;
        border-top: 1px solid #444;
        margin-top: 3rem;
        padding-top: 2rem;
        font-size: 0.875rem;
        color: #888;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .header-content {
          flex-direction: column;
          gap: 1rem;
        }

        .nav-menu ul {
          gap: 1rem;
          font-size: 0.9rem;
        }

        .footer-content {
          flex-direction: column;
          text-align: center;
        }
      }
    </style>
  </body>
</html>
